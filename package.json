    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prisma": "7.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "tar-fs": "^3.1.1",
    "ws": "^8.18.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
