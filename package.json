{
  "name": "alertas-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "test": "NODE_OPTIONS=--no-deprecation jest --runInBand --coverage --silent",
    "test:captura": "NODE_OPTIONS=--no-deprecation jest --runInBand --coverage --silent --collectCoverageFrom=autenticacion/aplicacion/casos-uso/decodificar-token.use-case.ts --collectCoverageFrom=integraciones/aplicacion/casos-uso/encontrar-departamento.use-case.ts --collectCoverageFrom=victimas/aplicacion/casos-uso/verificar-denuncia.use-case.ts --collectCoverageFrom=victimas/aplicacion/casos-uso/validacion/verificar-codigo.use-case.ts --collectCoverageFrom=alertas/aplicacion/casos-uso/crear-alerta.use-case.ts --collectCoverageFrom=alertas/aplicacion/casos-uso/notificar-creacion-alerta.use-case.ts --collectCoverageFrom=victimas/aplicacion/casos-uso/investigadores/asignar-investigador.use-case.ts --collectCoverageFrom=victimas/aplicacion/casos-uso/investigadores/desasignar-investigador.use-case.ts --collectCoverageFrom=victimas/aplicacion/casos-uso/web/suspender-cuenta.use-case.ts --collectCoverageFrom=dashboard/aplicacion/casos-uso/obtener-metricas-generales.use-case.ts --collectCoverageFrom=dashboard/aplicacion/casos-uso/obtener-alertas-por-ubicacion.use-case.ts --collectCoverageFrom=dashboard/infraestructura/adaptadores/monitor-sistema.adapter.ts",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "pm2:dev": "pnpm build && pm2 start ecosystem.config.js --env development --update-env && pm2 logs alertas-api --lines 100",
    "pm2:prod": "pnpm build && pm2 start ecosystem.config.js --env production --update-env && pm2 logs alertas-api --lines 100",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pnpm build && pm2 restart ecosystem.config.js --update-env && pm2 logs alertas-api --lines 100",
    "pm2:reload": "pnpm build && pm2 reload ecosystem.config.js --update-env && pm2 logs alertas-api --lines 100",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs alertas-api --lines 100",
    "pm2:monit": "pm2 monit alertas-api",
    "prepare": "husky",
    "format": "biome format --write src",
    "format:check": "biome format --check src",
    "lint": "biome check --write --unsafe src",
    "lint:check": "biome check src"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.6",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "7.2.0",
    "@scalar/nestjs-api-reference": "^1.0.13",
    "@turf/turf": "^7.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "expo-server-sdk": "^4.0.0",
    "firebase-admin": "^13.5.0",
    "form-data": "^4.0.4",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "pm2": "^6.0.14",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.6",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "artillery": "^2.0.30",
    "artillery-engine-socketio-v3": "^1.2.0",
    "dotenv": "^17.2.3",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prisma": "7.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "tar-fs": "^3.1.1",
    "ws": "^8.18.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
