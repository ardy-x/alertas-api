{
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#fa1b49",
    "activityBar.background": "#fa1b49",
    "activityBar.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#e7e7e799",
    "activityBarBadge.background": "#155e02",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#fa1b49",
    "statusBar.background": "#dd0531",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#fa1b49",
    "statusBarItem.remoteBackground": "#dd0531",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#dd0531",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#dd053199",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "peacock.color": "#dd0531",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "prettier.enable": false,
  "eslint.enable": false,
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Genera siempre el mensaje del commit en español."
    },
    {
      "text": "Mantén el formato de Conventional Commits (feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert). y con scope siempre"
    },
    { "text": "Usa imperativo (ej: 'agrega' en lugar de 'agregado')." }
  ],
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  }
}
